# Backend origin. Leave unset to use the Vite dev proxy at /api (see vite.config.ts).
# Hosted previews (e.g. Lovable) must set this to your deployed API (https://...).
# VITE_API_URL=http://localhost:3000

# Optional default studio slug; sent as X-Studio-Slug on API requests (e.g. local dev).
VITE_STUDIO_SLUG=
