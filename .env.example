# Backend origin. Leave unset to use the Vite dev proxy at /api (see vite.config.ts).
# VITE_API_URL=http://localhost:3000

# Default studio slug for API calls (X-Studio-Slug) when using localhost without a subdomain.
VITE_STUDIO_SLUG=

# Set to "true" to skip login and use a mock authenticated session (dev only).
# VITE_BYPASS_AUTH=true
