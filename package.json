{
    "name": "site-index",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": "22.x",
        "npm": "10.x"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "knip": "knip --config knip.json",
        "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
        "_prettier:normalize-cache": "node -e \"const fs = require('node:fs'); const dir = 'node_modules/.cache/prettier'; const cache = dir + '/.prettier-cache'; if (fs.existsSync(dir) && !fs.statSync(dir).isDirectory()) fs.rmSync(dir, { force: true }); fs.mkdirSync(dir, { recursive: true }); if (fs.existsSync(cache) && fs.statSync(cache).isDirectory()) fs.rmSync(cache, { recursive: true, force: true });\"",
        "preformat": "npm run _prettier:normalize-cache",
        "format": "prettier --write . --cache --cache-location node_modules/.cache/prettier/.prettier-cache",
        "preformat:files": "npm run _prettier:normalize-cache",
        "format:files": "prettier --write --cache --cache-location node_modules/.cache/prettier/.prettier-cache",
        "preformat:check": "npm run _prettier:normalize-cache",
        "format:check": "prettier --check . --cache --cache-location node_modules/.cache/prettier/.prettier-cache",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc -b",
        "full-check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
        "prepare": "husky"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.9",
        "@hookform/resolvers": "^5.2.2",
        "@tanstack/react-query": "^5.96.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fuse.js": "^7.3.0",
        "lucide-react": "^1.7.0",
        "next-themes": "^0.4.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.1",
        "react-router-dom": "^7.14.0",
        "recharts": "^3.8.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-node": "^0.3.10",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "knip": "^6.3.0",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.2"
    }
}
