        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "embla-carousel-react": "^8.6.0",
        "fuse.js": "^7.1.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^1.7.0",
        "next-themes": "^0.4.6",
        "react": "^19.2.4",
        "react-day-picker": "^9.14.0",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.0",
        "react-resizable-panels": "^4.8.0",
        "react-router-dom": "^7.13.2",
